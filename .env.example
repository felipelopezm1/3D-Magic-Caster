# Anthropic (required for wizard orchestration)
ANTHROPIC_API_KEY=

# Blender connection (addon socket; default local)
BLENDER_HOST=localhost
BLENDER_PORT=9876

# Optional: override MCP server command (default: uvx blender-mcp)
# MCP_COMMAND=uvx
# MCP_ARGS=blender-mcp

# Output folder for OBJ/FBX exports (default: ~/Downloads/3D-Magic-Caster-exports)
# OUTPUT_FOLDER=/path/to/your/downloads

# Server
PORT=3001
